# =============================================================================
# CollegeCompass — Required Environment Variables
# Copy this file to .env for local development (never commit .env)
# Set these as Railway environment variables for production deployment
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# On Railway: add a Postgres plugin and Railway sets this automatically.
DATABASE_URL=postgresql://user:password@localhost:5432/collegecompass

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign and verify JWT tokens. Must be a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED — the server will refuse to start without this.
SESSION_SECRET=change-me-to-a-long-random-secret-at-least-64-chars

# ── Runtime ──────────────────────────────────────────────────────────────────
# Must be "production" on Railway to enable:
#   • Static file serving (Express serves the Vite-built frontend)
#   • JSON-only pino logging (no pretty-print)
NODE_ENV=production

# PORT is set automatically by Railway — do not set it manually.
# PORT=8080

# ── Optional ─────────────────────────────────────────────────────────────────
# Log level for pino. Defaults to "info". Options: trace, debug, info, warn, error, fatal.
# LOG_LEVEL=info
